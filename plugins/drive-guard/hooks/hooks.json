{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Edit|Write|MultiEdit|NotebookEdit|NotebookRead|Glob|Grep|LS|Bash|mcp__claude_ai_Google_Drive__.*",
        "hooks": [
          {
            "type": "command",
            "command": "sh",
            "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/run-guard.sh", "${CLAUDE_PLUGIN_ROOT}/scripts/drive-guard.py", "--mode", "block"]
          }
        ]
      }
    ]
  }
}
